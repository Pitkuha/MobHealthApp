{
  "name": "mob-health-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:localhost": "expo start --localhost --clear",
    "start:tunnel": "expo start --tunnel --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "server:dev": "cd server && npm run dev",
    "server:typecheck": "cd server && npm run typecheck",
    "server:test": "cd server && npm run test",
    "desktop:install": "cd desktop && npm install",
    "desktop:dev": "cd desktop && npm run dev",
    "desktop:typecheck": "cd desktop && npm run typecheck",
    "desktop:build": "cd desktop && npm run build"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "expo": "^52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.1",
    "expo-notifications": "~0.29.14",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-calendars": "^1.1313.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.6.3"
  }
}
