generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELED
}

model User {
  id             String             @id @default(uuid())
  role           Role
  fullName       String
  email          String             @unique
  passwordHash   String
  age            Int?
  specialty      String?
  about          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  sentMessages   ChatMessage[]      @relation("MessageFrom")
  receivedMessages ChatMessage[]    @relation("MessageTo")

  doctorLinks    DoctorPatientLink[] @relation("DoctorLink")
  patientLink    DoctorPatientLink?  @relation("PatientLink")

  doctorReferrals ReferralCode[]     @relation("DoctorReferral")
  usedReferralCode ReferralCode?     @relation("UsedReferral")

  pushTokens     PushToken[]
  reminders      LessonReminder[]
}

model DoctorPatientLink {
  id         String   @id @default(uuid())
  doctorId   String
  patientId  String   @unique
  createdAt  DateTime @default(now())

  doctor     User     @relation("DoctorLink", fields: [doctorId], references: [id])
  patient    User     @relation("PatientLink", fields: [patientId], references: [id])

  @@unique([doctorId, patientId])
}

model WeekProgram {
  id          String   @id @default(uuid())
  weekNumber  Int      @unique
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
}

model Lesson {
  id            String   @id @default(uuid())
  weekProgramId String
  title         String
  description   String
  date          DateTime
  audioUrl      String
  durationMin   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  weekProgram   WeekProgram @relation(fields: [weekProgramId], references: [id])
  reminders     LessonReminder[]
}

model ReferralCode {
  id               String   @id @default(uuid())
  code             String   @unique
  doctorId         String
  active           Boolean  @default(true)
  usedByPatientId  String?  @unique
  createdAt        DateTime @default(now())

  doctor           User     @relation("DoctorReferral", fields: [doctorId], references: [id])
  usedByPatient    User?    @relation("UsedReferral", fields: [usedByPatientId], references: [id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  text      String
  createdAt DateTime @default(now())

  from      User     @relation("MessageFrom", fields: [fromId], references: [id])
  to        User     @relation("MessageTo", fields: [toId], references: [id])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model LessonReminder {
  id           String         @id @default(uuid())
  userId       String
  lessonId     String
  remindAt     DateTime
  status       ReminderStatus @default(PENDING)
  sentAt       DateTime?
  createdAt    DateTime       @default(now())

  user         User           @relation(fields: [userId], references: [id])
  lesson       Lesson         @relation(fields: [lessonId], references: [id])

  @@index([status, remindAt])
}
